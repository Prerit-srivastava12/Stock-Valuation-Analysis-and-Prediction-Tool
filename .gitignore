# Python

__pycache__/     # Stores compiled python files
*.py[cod]        # Compiled python files
*.egg-info/      # Metadata from python packages
.env             # Environment variables
venv/,.venv/     # Virtual Environments

# Data (raw data can be regenerated by running the pipeline)

data/raw/          # Original Datasets
data/processed/    # Cleaned/Transformed Data

# Outputs (regenerated each run; commit selectively)

outputs/charts/   
outputs/*.txt

# Jupyter

.ipynb_checkpoints/    # Auto saved notebook backups
*.ipynb                # All Jupyter notebooks

# OS

.DS_Store     # Mac system files
Thumbs.db     # Windows image cache

# IDE

.vscode/    # VS Code settings
.idea/      # Intellij/PyCharm settings
